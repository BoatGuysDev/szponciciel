# DATABASE_URL overrides the default sqlite:///szponciciel.db.
# When unset, RUN_MODE=test uses sqlite:///:memory: and everything
# else uses the project default.
# DATABASE_URL=sqlite:///szponciciel.db

RUN_MODE=development

ZERNIO_API_KEY=your-api-key
GROUND_TRUTH_MEDIA_ACCOUNT_ID=account-id

GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your-project-id
MODEL=gemini-2.5-flash-lite

COMPUTE_DEVICE=cpu
