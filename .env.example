# Runtime: development | test | production
RUN_MODE=development

# SQLite DB file (ignored when RUN_MODE=test — tests use in-memory SQLite)
DB_PATH=szponciciel.db

# Media root for stock video assets
# MEDIA_ROOT=media

# Compute device for TTS + WhisperX: cpu | cuda | mps
COMPUTE_DEVICE=cpu

# WhisperX model size for align_node: tiny | base | small | medium | large-v3
WHISPER_MODEL=base

# Coqui TTS model used by tts_node
TTS_MODEL=tts_models/multilingual/multi-dataset/xtts_v2

# Gemini model used by narrator + caption nodes
MODEL=gemini-2.5-flash-lite

# Google GenAI / Vertex auth (read directly by the Google SDK)
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_GENAI_USE_VERTEXAI=true

# Zernio (TikTok upload) — read by the Zernio SDK
ZERNIO_API_KEY=your-api-key

# Required only when seeding the ground_truth_media persona
GROUND_TRUTH_MEDIA_ACCOUNT_ID=account-id
